/**
 * Design Tokens - Variables SASS Completas
 * Variables SASS para usar con @use y @import
 */

// === COLORES ===
// Surface colors
$color-surface-primary: #ffffff;
$color-surface-secondary: #f8f9fa;
$color-surface-tertiary: #f1f3f4;
 * Incluye variables y clases para uso con @import
 */

// Importar variables SASS
@import 'tokens/variables';

// CSS Custom Properties para soporte de temas
:root {
  // Surface colors
  --color-surface-primary: #{$color-surface-primary};
  --color-surface-secondary: #{$color-surface-secondary};
  --color-surface-tertiary: #{$color-surface-tertiary};
  --color-surface-hover: #{$color-surface-hover};
  --color-surface-selected: #{$color-surface-selected};
  --color-surface-disabled: #{$color-surface-disabled};

  // Text colors
  --color-text-primary: #{$color-text-primary};
  --color-text-secondary: #{$color-text-secondary};
  --color-text-tertiary: #{$color-text-tertiary};
  --color-text-disabled: #{$color-text-disabled};

  // Brand colors
  --color-primary-500: #{$color-primary-500};
  --color-primary-600: #{$color-primary-600};
  --color-primary-700: #{$color-primary-700};

  // Borders
  --color-border-subtle: #{$color-border-subtle};
  --color-border-default: #{$color-border-default};
  --color-border-strong: #{$color-border-strong};

  // Overlay
  --color-overlay-backdrop: #{$color-overlay-backdrop};

  // Espaciado
  --spacing-2xs: #{$spacing-2xs};
  --spacing-xs: #{$spacing-xs};
  --spacing-sm: #{$spacing-sm};
  --spacing-md: #{$spacing-md};
  --spacing-lg: #{$spacing-lg};
  --spacing-xl: #{$spacing-xl};
  --spacing-2xl: #{$spacing-2xl};
  --spacing-3xl: #{$spacing-3xl};

  // Tamaños
  --size-lg: #{$size-lg};
  --size-xl: #{$size-xl};
  --size-2xl: #{$size-2xl};
  --size-3xl: #{$size-3xl};

  // Tipografía
  --font-family-ui: #{$font-family-ui};
  --font-size-xs: #{$font-size-xs};
  --font-size-sm: #{$font-size-sm};
  --font-size-base: #{$font-size-base};
  --font-size-lg: #{$font-size-lg};
  --font-size-xl: #{$font-size-xl};
  --font-size-2xl: #{$font-size-2xl};

  --font-weight-regular: #{$font-weight-regular};
  --font-weight-medium: #{$font-weight-medium};
  --font-weight-semibold: #{$font-weight-semibold};
  --font-weight-bold: #{$font-weight-bold};

  --line-height-tight: #{$line-height-tight};
  --line-height-relaxed: #{$line-height-relaxed};

  // Bordes
  --border-radius-sm: #{$border-radius-sm};
  --border-radius-md: #{$border-radius-md};
  --border-radius-full: #{$border-radius-full};

  // Sombras
  --shadow-sm: #{$shadow-sm};
  --shadow-xl: #{$shadow-xl};

  // Movimiento
  --duration-fast: #{$duration-fast};
  --duration-normal: #{$duration-normal};
  
  --easing-standard: #{$easing-standard};
  --easing-entrance: #{$easing-entrance};

  // Z-index
  --z-index-sticky: #{$z-index-sticky};
  --z-index-modal: #{$z-index-modal};
}

// Tema oscuro
[data-theme="dark"] {
  --color-surface-primary: #212529;
  --color-surface-secondary: #343a40;
  --color-surface-tertiary: #495057;
  
  --color-text-primary: #ffffff;
  --color-text-secondary: #dee2e6;
  --color-text-tertiary: #ced4da;
  
  --color-primary-400: #3399ff;
  --color-primary-600: #3399ff;
  
  --color-border-subtle: #6c757d;
  --color-border-default: #adb5bd;
  
  --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.3);
  --shadow-xl: 0 20px 25px -5px rgba(0, 0, 0, 0.4), 0 10px 10px -5px rgba(0, 0, 0, 0.3);
}

// Modo automático oscuro
@media (prefers-color-scheme: dark) {
  :root:not([data-theme]) {
    --color-surface-primary: #212529;
    --color-surface-secondary: #343a40;
    --color-surface-tertiary: #495057;
    
    --color-text-primary: #ffffff;
    --color-text-secondary: #dee2e6;
    --color-text-tertiary: #ced4da;
    
    --color-primary-400: #3399ff;
    --color-primary-600: #3399ff;
    
    --color-border-subtle: #6c757d;
    --color-border-default: #adb5bd;
    
    --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.3);
    --shadow-xl: 0 20px 25px -5px rgba(0, 0, 0, 0.4), 0 10px 10px -5px rgba(0, 0, 0, 0.3);
  }
}

// === UTILIDADES ===
.u-visually-hidden {
  position: absolute;
  width: 1px;
  height: 1px;
  padding: 0;
  margin: -1px;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  white-space: nowrap;
  border: 0;
}

.u-focus-visible {
  outline: 2px solid var(--color-primary-500);
  outline-offset: 2px;
}

.u-hover-interactive {
  cursor: pointer;
  transition: background-color var(--duration-normal) var(--easing-standard);
  
  &:hover {
    background-color: var(--color-surface-hover);
  }
}

// Variables para modo oscuro
[data-theme="dark"] {
  // === COLORES ===
  // Surface colors
  --color-surface: #212529;
  --color-surface-secondary: #343a40;
  --color-surface-tertiary: #495057;
  --color-surface-hover: #495057;
  --color-surface-active: #001a33;
  --color-surface-disabled: #343a40;

  // Text colors
  --color-on-surface: #ffffff;
  --color-on-surface-secondary: #dee2e6;
  --color-on-surface-tertiary: #ced4da;
  --color-on-surface-disabled: #6c757d;
  
  // Brand colors
  --color-brand: #3399ff;
  --color-on-brand: #212529;
  --color-brand-hover: #66b3ff;
  --color-brand-active: #99ccff;
  --color-brand-disabled: #6c757d;

  // Borders
  --color-border: #6c757d;
  --color-border-hover: #adb5bd;
  --color-border-focus: #3399ff;
  --color-border-disabled: #495057;

  // Shadows
  --color-shadow: rgba(0, 0, 0, 0.3);
  --color-shadow-focus: #3399ff40;

  // States
  --color-success: #4ade80;
  --color-on-success: #212529;
  --color-warning: #fbbf24;
  --color-on-warning: #212529;
  --color-danger: #f87171;
  --color-on-danger: #212529;
  --color-info: #38bdf8;
  --color-on-info: #212529;

  // Sombras para modo oscuro
  --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.3);
  --shadow-base: 0 1px 3px 0 rgba(0, 0, 0, 0.4), 0 1px 2px 0 rgba(0, 0, 0, 0.3);
  --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.4), 0 2px 4px -1px rgba(0, 0, 0, 0.3);
  --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.4), 0 4px 6px -2px rgba(0, 0, 0, 0.3);
  --shadow-xl: 0 20px 25px -5px rgba(0, 0, 0, 0.4), 0 10px 10px -5px rgba(0, 0, 0, 0.3);
  --shadow-2xl: 0 25px 50px -12px rgba(0, 0, 0, 0.6);
  --shadow-inner: inset 0 2px 4px 0 rgba(0, 0, 0, 0.3);
  --shadow-focus: 0 0 0 3px rgba(59, 130, 246, 0.3);
  --shadow-focus-brand: 0 0 0 3px rgba(0, 123, 255, 0.4);
}

// Utilidades de espaciado para mayor comodidad
@each $size, $value in (
  0: 0px,
  1: 4px,
  2: 8px,
  3: 12px,
  4: 16px,
  5: 20px,
  6: 24px,
  8: 32px,
  12: 48px,
  16: 64px
) {
  .m-#{$size} { margin: $value !important; }
  .mt-#{$size} { margin-top: $value !important; }
  .mb-#{$size} { margin-bottom: $value !important; }
  .ml-#{$size} { margin-left: $value !important; }
  .mr-#{$size} { margin-right: $value !important; }
  .mx-#{$size} { 
    margin-left: $value !important; 
    margin-right: $value !important; 
  }
  .my-#{$size} { 
    margin-top: $value !important; 
    margin-bottom: $value !important; 
  }
  
  .p-#{$size} { padding: $value !important; }
  .pt-#{$size} { padding-top: $value !important; }
  .pb-#{$size} { padding-bottom: $value !important; }
  .pl-#{$size} { padding-left: $value !important; }
  .pr-#{$size} { padding-right: $value !important; }
  .px-#{$size} { 
    padding-left: $value !important; 
    padding-right: $value !important; 
  }
  .py-#{$size} { 
    padding-top: $value !important; 
    padding-bottom: $value !important; 
  }
}

// Mixins para usar con componentes
@mixin typography($variant) {
  @if $variant == 'h1' {
    font-family: var(--font-family-ui);
    font-size: var(--font-size-4xl);
    line-height: var(--line-height-tight);
    font-weight: var(--font-weight-bold);
  } @else if $variant == 'h2' {
    font-family: var(--font-family-ui);
    font-size: var(--font-size-3xl);
    line-height: var(--line-height-tight);
    font-weight: var(--font-weight-bold);
  } @else if $variant == 'h3' {
    font-family: var(--font-family-ui);
    font-size: var(--font-size-2xl);
    line-height: var(--line-height-snug);
    font-weight: var(--font-weight-semibold);
  } @else if $variant == 'body-base' {
    font-family: var(--font-family-ui);
    font-size: var(--font-size-base);
    line-height: var(--line-height-normal);
    font-weight: var(--font-weight-regular);
  } @else if $variant == 'body-small' {
    font-family: var(--font-family-ui);
    font-size: var(--font-size-sm);
    line-height: var(--line-height-normal);
    font-weight: var(--font-weight-regular);
  }
}

@mixin button-base {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: var(--spacing-1) solid transparent;
  border-radius: var(--radius-base);
  font-family: var(--font-family-ui);
  font-weight: var(--font-weight-medium);
  text-decoration: none;
  cursor: pointer;
  transition: all var(--duration-fast) var(--easing-standard);
  min-height: var(--spacing-8);
  padding: var(--spacing-2) var(--spacing-4);
  
  &:focus-visible {
    outline: none;
    box-shadow: var(--shadow-focus-brand);
  }
  
  &:disabled {
    cursor: not-allowed;
    opacity: 0.5;
  }
}

@mixin surface {
  background-color: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-base);
  box-shadow: var(--shadow-sm);
}