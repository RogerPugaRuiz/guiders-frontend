@use '../../../../../../shared/design-tokens/tokens.scss' as tokens;
@use 'sass:color';

/* Estilos Bento UI para vista de visitantes */

:host {
  display: block;
}

.visitors-page {
  display: flex;
  flex-direction: column;
  gap: tokens.$spacing-md;
  padding: tokens.$spacing-xl;
  max-width: 100%;
  overflow-x: auto;
}

/* Header card simplificado */
.visitors-header-card .page-header {
  display: flex;
  justify-content: flex-start;
  align-items: center;
  gap: tokens.$spacing-md;
  padding: tokens.$spacing-xl;
}

.page-info {
  display: flex;
  flex-direction: column;
  gap: tokens.$spacing-xs;
  flex: 1;
}

.page-title {
  display: flex;
  align-items: center;
  gap: tokens.$spacing-sm;
  @include tokens.typography('h2');
  color: tokens.$color-text-primary;
  margin: 0;
}

.title-icon {
  font-size: tokens.$font-size-2xl;
  opacity: 0.8;
}

.page-description {
  @include tokens.typography('body-small');
  color: tokens.$color-text-secondary;
  margin: 0;
  margin-top: tokens.$spacing-xs;
}

/* Grid */
.visitors-grid {
  margin-top: tokens.$spacing-md;
}

/* Error content */
.error-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: tokens.$spacing-sm;
  padding: tokens.$spacing-xl;
  text-align: center;
  color: tokens.$color-text-secondary;
}

.error-content .error-icon {
  font-size: tokens.$font-size-2xl;
}

.error-content .error-text {
  @include tokens.typography('body-small');
}

.error-content .retry-button {
  background: tokens.$color-primary-500;
  color: tokens.$color-surface-primary;
  border: none;
  border-radius: tokens.$border-radius-md;
  padding: tokens.$spacing-2xs tokens.$spacing-md;
  @include tokens.typography('button');
  cursor: pointer;
  transition: background tokens.$duration-normal tokens.$easing-standard;

  &:hover {
    background: tokens.$color-primary-600;
  }

  &:active {
    background: tokens.$color-primary-700;
  }
}

/* Quick actions */
.quick-actions {
  display: flex;
  flex-direction: column;
  gap: tokens.$spacing-sm;
  height: 100%;
}

.action-button {
  display: flex;
  align-items: center;
  gap: tokens.$spacing-sm;
  padding: tokens.$spacing-sm;
  border-radius: tokens.$border-radius-md;
  background: tokens.$color-surface-primary;
  color: tokens.$color-text-primary;
  text-align: left;
  cursor: pointer;
  transition: all tokens.$duration-normal tokens.$easing-standard;
  flex: 1;
  box-shadow: 2px 2px 8px rgba(0, 0, 0, 0.1);
  border: none;

  &:hover {
    background: tokens.$color-surface-hover;
    box-shadow: 3px 3px 12px rgba(0, 0, 0, 0.15);
  }

  &:active {
    box-shadow: none;
  }

  &--primary {
    background: tokens.$color-surface-selected;
    color: tokens.$color-primary-700;
    box-shadow: 2px 2px 8px rgba(59, 130, 246, 0.15);

    &:hover {
      background: color.adjust(tokens.$color-surface-selected, $lightness: 3%);
      box-shadow: 3px 3px 12px rgba(59, 130, 246, 0.2);
    }
  }
}

.action-icon {
  font-size: tokens.$font-size-lg;
  flex-shrink: 0;
}

.action-content {
  display: flex;
  flex-direction: column;
  gap: tokens.$spacing-xs;
}

.action-title {
  @include tokens.typography('body-medium');
  font-weight: tokens.$font-weight-semibold;
  color: inherit;
}

.action-desc {
  @include tokens.typography('caption');
  color: tokens.$color-text-secondary;
}

/* Activity feed */
.activity-feed {
  display: flex;
  flex-direction: column;
  gap: tokens.$spacing-2xs;
  height: 100%;
}

.activity-item {
  display: flex;
  flex-direction: column;
  gap: tokens.$spacing-xs;
  padding: tokens.$spacing-2xs;
  border-left: 2px solid tokens.$color-primary-500;
  padding-left: tokens.$spacing-sm;
  position: relative;

  &::before {
    content: '';
    position: absolute;
    left: -4px;
    top: tokens.$spacing-2xs;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: tokens.$color-primary-500;
  }
}

.activity-time {
  @include tokens.typography('caption');
  color: tokens.$color-text-tertiary;
  font-weight: tokens.$font-weight-medium;
}

.activity-text {
  @include tokens.typography('body-small');
  color: tokens.$color-text-secondary;
}

/* Bento Grid System */
.bento-grid {
  display: grid;
  gap: tokens.$spacing-md;
  width: 100%;
  grid-auto-rows: minmax(120px, auto);

  &--4-cols {
    grid-template-columns: repeat(4, 1fr);
  }

  &--comfortable {
    gap: tokens.$spacing-xl;
  }
}

/* Bento Card Base */
.bento-card {
  background: tokens.$color-surface-primary;
  border-radius: tokens.$border-radius-md;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: all tokens.$duration-normal tokens.$easing-standard;
  box-shadow: 2px 2px 8px rgba(0, 0, 0, 0.1);

  &:hover {
    box-shadow: 3px 3px 12px rgba(0, 0, 0, 0.15);
  }

  &--outlined {
    background: transparent;
    box-shadow: 2px 2px 8px rgba(0, 0, 0, 0.08);
  }
}

/* Bento Card Sizes */
.bento-card--1x1 { grid-column: span 1; grid-row: span 1; }
.bento-card--2x1 { grid-column: span 2; grid-row: span 1; }
.bento-card--1x2 { grid-column: span 1; grid-row: span 2; }
.bento-card--2x2 { grid-column: span 2; grid-row: span 2; }
.bento-card--3x1 { grid-column: span 3; grid-row: span 1; }
.bento-card--1x3 { grid-column: span 1; grid-row: span 3; }
.bento-card--3x2 { grid-column: span 3; grid-row: span 2; }
.bento-card--2x3 { grid-column: span 2; grid-row: span 3; }

.bento-card-header {
  padding: tokens.$spacing-md tokens.$spacing-md 0;
  border-bottom: 1px solid tokens.$color-border-subtle;
  margin-bottom: tokens.$spacing-sm;
}

.bento-card-title {
  @include tokens.typography('body-medium');
  font-weight: tokens.$font-weight-semibold;
  color: tokens.$color-text-primary;
  margin: 0;
  padding-bottom: tokens.$spacing-2xs;
}

.bento-card-content {
  padding: 0 tokens.$spacing-md tokens.$spacing-md;
  flex: 1;
  overflow: auto;
}

/* Bento KPI Styles */
.bento-kpi {
  background: tokens.$color-surface-primary;
  border-radius: tokens.$border-radius-md;
  padding: tokens.$spacing-md;
  display: flex;
  flex-direction: column;
  height: 100%;
  transition: all tokens.$duration-normal tokens.$easing-standard;
  box-shadow: 2px 2px 8px rgba(0, 0, 0, 0.1);

  &:hover {
    box-shadow: 3px 3px 12px rgba(0, 0, 0, 0.15);
  }

  /* KPI Size variants */
  &--1x1 { grid-column: span 1; grid-row: span 1; }
  &--2x1 { grid-column: span 2; grid-row: span 1; }
  &--1x2 { grid-column: span 1; grid-row: span 2; }

  /* KPI Variant styles */
  &--primary {
    border-color: tokens.$color-primary-500;
    background: linear-gradient(135deg, tokens.$color-surface-selected 0%, tokens.$color-surface-primary 100%);

    .kpi-title { color: tokens.$color-primary-700; }
    .value-number { color: tokens.$color-primary-700; }
  }

  &--success {
    border-color: #16a34a;
    background: linear-gradient(135deg, #dcfce7 0%, tokens.$color-surface-primary 100%);

    .kpi-title { color: #15803d; }
    .value-number { color: #166534; }
  }

  &--warning {
    border-color: #f59e0b;
    background: linear-gradient(135deg, #fef3c7 0%, tokens.$color-surface-primary 100%);

    .kpi-title { color: #d97706; }
    .value-number { color: #92400e; }
  }

  &--neutral {
    border-color: tokens.$color-border-subtle;
    background: linear-gradient(135deg, tokens.$color-surface-secondary 0%, tokens.$color-surface-primary 100%);

    .kpi-title { color: tokens.$color-text-secondary; }
    .value-number { color: tokens.$color-text-primary; }
  }
}

.kpi-container {
  display: flex;
  flex-direction: column;
  gap: tokens.$spacing-2xs;
  height: 100%;
}

.kpi-header {
  display: flex;
  align-items: center;
  gap: tokens.$spacing-xs;
}

.kpi-icon {
  font-size: tokens.$font-size-sm;
}

.kpi-title {
  @include tokens.typography('caption');
  color: tokens.$color-text-secondary;
  text-transform: uppercase;
  letter-spacing: 0.025em;
  font-weight: tokens.$font-weight-medium;
}

.kpi-value {
  display: flex;
  align-items: baseline;
  gap: tokens.$spacing-xs;
  margin: tokens.$spacing-xs 0;
}

.value-number {
  font-size: tokens.$font-size-2xl;
  font-weight: tokens.$font-weight-bold;
  color: tokens.$color-text-primary;
  line-height: 1;
  font-feature-settings: 'tnum';
}

.kpi-trend {
  display: flex;
  align-items: center;
  gap: tokens.$spacing-xs;
  @include tokens.typography('caption');
  font-weight: tokens.$font-weight-medium;

  &[data-direction="up"] {
    color: #16a34a;
  }

  &[data-direction="down"] {
    color: #ef4444;
  }

  &[data-direction="stable"] {
    color: tokens.$color-text-secondary;
  }
}

.trend-icon {
  font-size: tokens.$font-size-xs;
}

/* Responsive adjustments */
@media (max-width: tokens.$breakpoint-lg) {
  .bento-grid--4-cols {
    grid-template-columns: repeat(3, 1fr);
  }
}

@media (max-width: tokens.$breakpoint-md) {
  .bento-grid--4-cols {
    grid-template-columns: repeat(2, 1fr);
  }
  
  .bento-grid {
    gap: tokens.$spacing-sm;
  }
}

@media (max-width: 480px) {
  .bento-grid--4-cols {
    grid-template-columns: 1fr;
  }

  .visitors-page {
    padding: tokens.$spacing-md;
  }
}