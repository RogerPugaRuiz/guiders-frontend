/**
 * Visitors List Component
 * Basado en la guía de diseño B2B Web Desktop
 * Cumple WCAG 2.2 AA
 */

@import '@guiders-frontend/design-tokens/src/lib/tokens.scss';

:host {
  display: block;
  height: 100%;
}

.visitors-list {
  display: flex;
  flex-direction: column;
  height: 100%;
  background-color: var(--color-surface);

  // Estadísticas
  .visitors-stats {
    display: flex;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    
    .stat-card { padding: 0.5rem; min-width: 64px; }
    .stat-number { font-weight: 600; }
    .stat-label { font-size: 0.75rem; opacity: 0.8; }
  }

  // Controles
  .visitors-controls {
    padding: 1rem;
    background: white;
    border-bottom: 1px solid #e9ecef;
    display: flex;
    flex-direction: column;
    gap: 1rem;

    .search-box {
      position: relative;
      max-width: 300px;

      .search-input {
        width: 100%;
        padding: 0.75rem 2.5rem 0.75rem 1rem;
        border: 1px solid #e5e7eb;
        border-radius: 6px;
        font-size: 0.9rem;
        /* transición reducida */

        &:focus {
          outline: none;
          border-color: #3b82f6;
          box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.2);
        }
      }

      .search-icon {
        position: absolute;
        right: 0.75rem;
        top: 50%;
        transform: translateY(-50%);
        color: #6b7280;
      }
    }

    .filter-controls {
      display: flex;
      flex-wrap: wrap;
      gap: 2rem;
      align-items: center;

      .filter-group {
        display: flex;
        align-items: center;
        gap: 0.5rem;

        .filter-label {
          font-weight: 500;
          color: #495057;
          font-size: 0.9rem;
        }

        .filter-options {
          display: flex;
          gap: 0.75rem;

          .filter-option {
            display: flex;
            align-items: center;
            gap: 0.25rem;
            cursor: pointer;
            font-size: 0.85rem;

            input[type="checkbox"] {
              margin: 0;
            }

            .option-text {
              user-select: none;
            }
          }
        }
      }

      /* sort-controls eliminados para reducir CSS */
    }
  }

  // Contenido principal
  .visitors-content {
    flex: 1;
    overflow-y: auto;
    padding: 1rem;

    .loading-state,
    .error-state,
    .empty-state {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 2rem 1rem;
      text-align: center;
      color: #6b7280;

      .spinner {
        width: 3rem;
        height: 3rem;
        border: 3px solid #e5e7eb;
        border-top: 3px solid #3b82f6;
        border-radius: 50%;
        margin-bottom: 1rem;
      }

      .error-icon,
      .empty-icon {
        font-size: 3rem;
        margin-bottom: 1rem;
      }

      h3 {
        margin: 0 0 0.5rem 0;
        color: #374151;
      }

      p {
        margin: 0 0 1rem 0;
        font-size: 0.9rem;
      }

      .retry-button {
        padding: 0.5rem 1rem;
  background: #3b82f6;
  color: #ffffff;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        font-size: 0.9rem;

        &:hover {
          background: #2563eb;
        }
      }
    }

    .visitors-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 1rem;

      .visitor-card {
        background: white;
        border-radius: 8px;
        padding: 1rem;
        border: 1px solid #e5e7eb;
        cursor: pointer;
        /* sin transición */
        position: relative;

        /* hover mínimo eliminado para reducir CSS */

        &:focus {
          outline: 2px solid #3b82f6;
          outline-offset: 2px;
        }

        &.selected {
          border-color: #3b82f6;
          background: #f3f6ff;
        }

        &.has-active-chat {
          border-left: 4px solid #16a34a;
        }

        .visitor-checkbox {
          position: absolute;
          top: 0.75rem;
          right: 0.75rem;
        }

        .visitor-avatar {
          display: flex;
          align-items: center;
          margin-bottom: 0.75rem;
          position: relative;

          .avatar-circle {
            width: 3rem;
            height: 3rem;
            border-radius: 50%;
            background: #e5e7eb;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #111827;
            font-weight: bold;
            font-size: 1.1rem;
            margin-right: 0.75rem;
          }

          .status-indicator {
            position: absolute;
            top: -2px;
            left: 2rem;
            font-size: 0.8rem;
          }
        }

        .visitor-info {
          .visitor-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 0.5rem;

            .visitor-name {
              margin: 0;
              font-size: 1rem;
              font-weight: 600;
              color: #212529;
            }

            .visitor-lifecycle {
              font-size: 1.1rem;
            }
          }

          .visitor-details {
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
            margin-bottom: 0.75rem;

            span {
              font-size: 0.85rem;
              color: #6c757d;
              display: flex;
              align-items: center;
              gap: 0.25rem;
            }

            .visitor-email { color: #2563eb; }
          }

          .active-chat-indicator {
            display: inline-flex;
            align-items: center;
            gap: 0.25rem;
            background: #e8f5ee;
            color: #166534;
            padding: 0.25rem 0.5rem;
            border-radius: 4px;
            font-size: 0.75rem;
            font-weight: 500;
            margin-bottom: 0.5rem;
          }

          /* tags eliminadas para un diseño más simple */
        }

        .visitor-actions {
          position: absolute;
          bottom: 0.75rem;
          right: 0.75rem;
          display: flex;
          gap: 0.25rem;

          .action-button {
            width: 2rem;
            height: 2rem;
            border: none;
            border-radius: 50%;
            cursor: pointer;
            font-size: 0.9rem;
            /* sin transición */

            &.create-chat {
              background: #16a34a;
              color: #ffffff;

              /* hover eliminado para reducir CSS */
            }

            &.view-details {
              background: #9ca3af;
              color: #111827;

              /* hover eliminado para reducir CSS */
            }
          }
        }
      }
    }
  }

  /* Controles de selección múltiple eliminados para reducir CSS */
}
/* Animaciones eliminadas por no ser críticas */

// Responsive
@media (max-width: 768px) {
  .visitors-list {
    .visitors-stats {
      overflow-x: auto;
      
      .stat-card {
        min-width: 70px;
      }
    }

    .visitors-controls {
      .filter-controls {
        flex-direction: column;
        align-items: stretch;
        gap: 1rem;
      }
    }

    .visitors-content .visitors-grid {
      grid-template-columns: 1fr;
    }

    .multi-select-controls {
      flex-direction: column;
      gap: 0.75rem;
      align-items: stretch;

      .bulk-actions {
        justify-content: center;
      }
    }
  }
}