{
  "name": "@guiders-frontend/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "serve": "nx serve console --port=4200",
    "serve:mock": "VITE_USE_MOCK_DATA=true nx serve console --port=4200",
    "serve:admin": "nx serve admin --port=4201",
    "serve:admin:mock": "VITE_USE_MOCK_DATA=true nx serve admin --port=4201",
    "dev": "nx serve console --configuration=development --port=4200",
    "dev:mock": "VITE_USE_MOCK_DATA=true nx serve console --configuration=development --port=4200",
    "dev:admin": "nx serve admin --configuration=development --port=4201",
    "dev:admin:mock": "VITE_USE_MOCK_DATA=true nx serve admin --configuration=development --port=4201",
    "build": "nx build console",
    "build:admin": "nx build admin",
    "build:all": "nx run-many -t build --projects=admin,console --parallel",
    "build:prod": "nx run-many -t build --configuration=production --projects=admin,console --parallel",
    "build:staging": "nx run-many -t build --configuration=staging --projects=admin,console --parallel",
    "test": "nx run-many -t test --projects=admin,console --parallel",
    "test:watch": "nx run-many -t test --projects=admin,console --parallel --watch",
    "test:coverage": "nx run-many -t test --projects=admin,console --parallel --configuration=ci",
    "lint": "nx run-many -t lint --projects=admin,console --parallel",
    "lint:fix": "nx run-many -t lint --projects=admin,console --parallel --fix",
    "e2e": "nx run-many -t e2e --projects=admin-e2e,console-e2e --parallel",
    "e2e:admin": "nx e2e admin-e2e",
    "e2e:console": "nx e2e console-e2e",
    "affected:build": "nx affected -t build",
    "affected:test": "nx affected -t test",
    "affected:lint": "nx affected -t lint",
    "affected:e2e": "nx affected -t e2e",
    "graph": "nx graph",
    "reset": "nx reset"
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "~20.1.0",
    "@angular/common": "~20.1.0",
    "@angular/compiler": "~20.1.0",
    "@angular/core": "~20.1.0",
    "@angular/forms": "~20.1.0",
    "@angular/material": "~20.1.0",
    "@angular/platform-browser": "~20.1.0",
    "@angular/router": "~20.1.0",
    "angular-auth-oidc-client": "^19.0.2",
    "rxjs": "~7.8.0",
    "socket.io-client": "^4.8.1",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "~1.19.1",
    "@analogjs/vitest-angular": "~1.19.1",
    "@angular-devkit/core": "~20.1.0",
    "@angular-devkit/schematics": "~20.1.0",
    "@angular/build": "~20.1.0",
    "@angular/cli": "~20.1.0",
    "@angular/compiler-cli": "~20.1.0",
    "@angular/language-service": "~20.1.0",
    "@eslint/js": "^9.8.0",
    "@nx/angular": "21.4.1",
    "@nx/devkit": "21.4.1",
    "@nx/eslint": "21.4.1",
    "@nx/eslint-plugin": "21.4.1",
    "@nx/js": "21.4.1",
    "@nx/playwright": "21.4.1",
    "@nx/vite": "21.4.1",
    "@nx/web": "21.4.1",
    "@nx/workspace": "21.4.1",
    "@playwright/test": "^1.36.0",
    "@schematics/angular": "~20.1.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^10.3.5",
    "@swc-node/register": "~1.9.1",
    "@swc/core": "^1.13.3",
    "@swc/helpers": "~0.5.11",
    "@types/node": "20.19.9",
    "@typescript-eslint/utils": "^8.29.0",
    "@vitest/coverage-v8": "^3.0.5",
    "@vitest/ui": "^3.0.0",
    "angular-eslint": "^20.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-playwright": "^1.6.2",
    "jiti": "2.4.2",
    "jsdom": "~22.1.0",
    "jsonc-eslint-parser": "^2.1.0",
    "ng-packagr": "~20.1.0",
    "nx": "21.4.1",
    "postcss": "^8.4.5",
    "postcss-url": "~10.1.3",
    "prettier": "^2.6.2",
    "semantic-release": "^24.2.9",
    "tslib": "^2.3.0",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.29.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
