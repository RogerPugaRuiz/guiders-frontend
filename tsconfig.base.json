{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "es2022",
    "module": "esnext",
    "lib": ["es2022", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@guiders-frontend/analytics/features/admin-dashboard": [
        "libs/analytics/features/admin-dashboard/src/index.ts"
      ],
      "@guiders-frontend/auth/features/login": [
        "libs/auth/features/login/src/index.ts"
      ],
      "@guiders-frontend/auth/ui/login-form": [
        "libs/auth/ui/login-form/src/index.ts"
      ],
      "@guiders-frontend/chat/features/inbox": [
        "libs/chat/features/inbox/src/index.ts"
      ],
      "@guiders-frontend/auth/data-access/session": [
        "libs/auth/data-access/session/src/index.ts"
      ]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
